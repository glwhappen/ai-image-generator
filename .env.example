# ============================================
# AI 创作室 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# ============================================
# 数据库配置（PostgreSQL / Supabase）
# ============================================

# 数据库连接 URL
# 
# 方式一：Supabase Cloud REST API（推荐）
# 从 Supabase 项目设置 -> API -> Project URL 获取
# COZE_SUPABASE_URL=https://your-project.supabase.co
# 
# 方式二：PostgreSQL 直连（适用于自建或直连模式）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# COZE_SUPABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# 
# 方式三：Docker Compose 内部连接
# COZE_SUPABASE_URL=postgresql://postgres:postgres123@postgres:5432/ai_studio
#
# 方式四：火山引擎托管 Supabase
# 从火山引擎控制台获取数据库连接信息，格式：
# COZE_SUPABASE_URL=postgresql://postgres:your-password@br-xxx.supabase2.aidap-global.cn-beijing.volces.com:5432/postgres
#
# 注意：
# - 如果 URL 包含 :5432 端口或 postgresql:// 协议，会自动使用 PostgreSQL 直连模式
# - 如果 URL 是 https://xxx.supabase.co 格式，会使用 Supabase REST API
# - 火山引擎托管 Supabase 必须使用 PostgreSQL 直连模式
COZE_SUPABASE_URL=postgresql://postgres:postgres123@postgres:5432/ai_studio

# 数据库 Anon Key（用于客户端访问）
# 本地 PostgreSQL 可以使用任意值
# Supabase Cloud 需要从项目设置中获取
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsIiwicm9sZSI6ImFub24iLCJpYXQiOjE2NDc2NjY0MDAsImV4cCI6MTk2MzI0MjQwMH0.local-anon-key-placeholder

# ============================================
# 对象存储配置（MinIO / S3 兼容服务）
# ============================================

# 存储服务端点 URL
# Docker Compose 默认值：
# COZE_BUCKET_ENDPOINT_URL=http://minio:9000
# 
# AWS S3 示例：
# COZE_BUCKET_ENDPOINT_URL=https://s3.amazonaws.com
# 
# 阿里云 OSS 示例：
# COZE_BUCKET_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
COZE_BUCKET_ENDPOINT_URL=http://minio:9000

# 存储桶名称
COZE_BUCKET_NAME=ai-images

# 访问密钥
# Docker Compose 默认值：minioadmin
COZE_BUCKET_ACCESS_KEY=minioadmin

# 私密密钥
# Docker Compose 默认值：minioadmin123
COZE_BUCKET_SECRET_KEY=minioadmin123

# 区域
# Docker Compose 默认值：us-east-1
COZE_BUCKET_REGION=us-east-1

# ============================================
# 应用配置（可选）
# ============================================

# Node 环境
NODE_ENV=production

# 端口（默认 3000）
PORT=3000

# ============================================
# AI 模型配置（可选）
# ============================================

# OpenAI / GPT 图片生成 API 配置
# 用于 GPT 图片生成（gpt-image-1, gpt-image-2, dall-e-3 等）
# 如果不配置，用户需要在前端设置面板手动填写
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_API_KEY=sk-your-openai-api-key

# Gemini 图片生成 API 配置
# 用于 Gemini 图片生成
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_API_KEY=your-gemini-api-key

# 豆包图片生成 Bearer Token（Coze 集成）
# 用于免费的豆包图片生成服务
# 格式：从 Coze 平台获取的 Token（不含 "Bearer " 前缀）
# DOUBAO_BEARER_TOKEN=UXFMU2luMGp4MzlZNmQzVlhtWTdISkFjV25idHRCY3g6...

# ============================================
# 前端配置说明
# ============================================
# 如果服务端未配置上述环境变量，用户需要在前端"设置"面板中手动填写：
# 
# Gemini:
# - Base URL: https://generativelanguage.googleapis.com
# - API Key: your-gemini-api-key
# - Model: gemini-3.1-flash-image-preview（默认）
# 
# OpenAI:
# - Base URL: https://api.openai.com
# - API Key: your-openai-api-key
# - Model: gpt-image-1, gpt-image-2 或 dall-e-3
# 
# 其他兼容服务（如 OpenRouter、Azure 等）：
# - Base URL: 按服务商文档填写
# - API Key: 服务商提供的密钥
# - Model: 支持图片生成的模型名称
